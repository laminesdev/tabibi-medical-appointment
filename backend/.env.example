# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tabibi

# JWT
JWT_SECRET=your-super-secret-key-that-is-at-least-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-key-that-is-also-at-least-32-chars

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Redis (optional)
REDIS_URL=

# Frontend
FRONTEND_URL=http://localhost:3000
